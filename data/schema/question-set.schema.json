{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://game-for-child/schemas/question-set.schema.json",
  "title": "QuestionSet",
  "description": "Tập hợp câu hỏi — một file JSON có thể chứa nhiều câu hỏi cùng chủ đề/trường/kỹ năng",
  "type": "object",
  "required": ["version", "set_id", "questions"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Phiên bản schema",
      "const": "1.0.0"
    },
    "set_id": {
      "type": "string",
      "description": "Mã tập câu hỏi. VD: arch-math-pattern-v1"
    },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "school": { "type": "string" },
    "skill": { "type": "string" },
    "difficulty_range": {
      "type": "array",
      "items": { "type": "integer", "minimum": 1, "maximum": 4 },
      "minItems": 1,
      "maxItems": 4
    },
    "total_questions": { "type": "integer" },
    "questions": {
      "type": "array",
      "items": { "$ref": "question.schema.json" }
    }
  }
}
